# Mesa de Ayuda / Playwright
MESA_AYUDA_URL=http://mesaayuda.intranet.pjud/mesa_ayuda/index.php
MESA_AYUDA_USER=
MESA_AYUDA_PASSWORD=
MESA_AYUDA_HEADLESS=false
MESA_AYUDA_SOLO_LECTURA=true
MESA_AYUDA_PERMITIR_RESPUESTA=false
MESA_AYUDA_PERMITIR_DESCARGA_ADJUNTOS=true
MESA_AYUDA_TIMEOUT=60000
MESA_AYUDA_PLAYWRIGHT_PATH=tools/mesa-ayuda-playwright

# OpenAI / agentes
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-thinking
AGENTES_LOG_PROMPTS=true
AGENTES_LOG_RESPONSES=true
AGENTES_MAX_RETRIES=2
AGENTES_TIMEOUT=120

AGENTE_CLASIFICADOR_MODEL=${OPENAI_MODEL}
AGENTE_LECTOR_DOCUMENTOS_MODEL=${OPENAI_MODEL}
AGENTE_CDP_MODEL=${OPENAI_MODEL}
AGENTE_VALIDADOR_MODEL=${OPENAI_MODEL}
AGENTE_REDACTOR_MODEL=${OPENAI_MODEL}

# Usuarios técnicos / agentes
AGENTE_ORQUESTADOR_USER=agente.orquestador
AGENTE_EXTRACTOR_USER=agente.extractor.mesa_ayuda
AGENTE_IMPORTADOR_USER=agente.importador_json
AGENTE_CLASIFICADOR_USER=agente.clasificador_cdp
AGENTE_LECTOR_DOCUMENTOS_USER=agente.lector_documentos
AGENTE_REDACTOR_CDP_USER=agente.redactor_cdp
AGENTE_VALIDADOR_CDP_USER=agente.validador_cdp
AGENTE_RESPUESTA_MESA_AYUDA_USER=agente.respuesta_mesa_ayuda
